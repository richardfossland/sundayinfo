# Supabase — SundayPlan project (the SSO issuer; tenancy tables public.church /
# public.church_member live there). SundayInfo owns the dedicated `info` schema.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Cross-subdomain SSO cookie (production only; leave unset for localhost).
NEXT_PUBLIC_COOKIE_DOMAIN=.sundaysuite.app

# Public base URL used in pairing instructions + QR codes.
NEXT_PUBLIC_BASE_URL=https://info.sundaysuite.app

# AI "lim inn → ferdig slide-pakke" (OPTIONAL). Server-only Anthropic key —
# in production a Cloudflare Worker secret (`npx wrangler secret put
# ANTHROPIC_API_KEY`), NEVER in a client bundle. Unset → /api/compose degrades
# gracefully to the offline parseRawText heuristic; nothing breaks.
ANTHROPIC_API_KEY=sk-ant-...
